APP_ENV=production
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=hire-ready-ai
ACCESS_TOKEN_MINUTES=60
AUTH_COOKIE_NAME=hire_ready_session
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# Used once when the users table is empty. Remove after the first successful startup.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password

DATABASE_PATH=/app/data/app.db
CORS_ALLOWED_ORIGINS=https://your-domain.example
ALLOWED_HOSTS=your-domain.example,localhost,127.0.0.1
API_DOCS_ENABLED=false
CODE_EXECUTION_ENABLED=false
MAX_UPLOAD_BYTES=10485760

MISTRAL_API_KEY=replace-with-your-mistral-key
MISTRAL_API_MODEL_NAME=mistral-large-latest
